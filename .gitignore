# Çevresel Değişkenler ve Şifreler (KRİTİK)
.env
settings.json

# Veritabanı Dosyaları
*.db
*.sqlite3

# Kullanıcı Yüklemeleri (Medyalar vs.)
uploads/

# Python ve Sanal Ortam
__pycache__/
.venv/
venv/

# IDE (PyCharm Ayarları)
.idea/

# Flask instance klasörü: Klasörün kendisi Git'te olsun ki sunucuda clone'dan sonra
# hazır gelsin. Ama içindeki veritabanı ve loglar Git'e ASLA düşmesin.
instance/*
!instance/.gitkeep
