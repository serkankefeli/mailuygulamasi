# ----------------------------------------
# MAILKAMP - ORNEK ENV DOSYASI (.env.example)
# ----------------------------------------
# Bu dosyayı SUNUCUDA '.env' olarak kopyalayın ve degerleri doldurun.
# docker-compose up -d komutu .env'yi otomatik okur.

# 1. Calisma Ortami: PRODUCTION'DA mutlaka 'production' yap.
#    Aksi halde session cookie'leri HTTP üzerinden aktarılır (güvenlik açığı).
MAILKAMP_ENV=production

# 2. Flask Gizli Anahtari (oturum + unsubscribe HMAC icin)
#    Yeni bir tane uret:  python -c "import secrets; print(secrets.token_hex(32))"
#    ASLA paylasma, repoya commit'leme.
MAILKAMP_SECRET_KEY=

# 3. Kurucu Admin Ilk Sifresi
#    Veritabani bos olursa admin hesabi bu sifreyle kurulur.
#    Guclu bir sey yaz (min 12 karakter, karma).
ADMIN_INITIAL_PASSWORD=

# 4. Admin SMTP Uygulama Sifresi (Gmail/Yandex App Password, 16 hane)
#    Sifre sifirlama ve sistem mailleri bu hesaptan gider.
ADMIN_SMTP_PASSWORD=

# 5. Yonlendirme Allowlist (bos birakabilirsin)
MAILKAMP_REDIRECT_ALLOWLIST=

# 6. Fernet Sifreleme Anahtari (kullanici SMTP sifrelerini sifrelemek icin)
#    Yeni uret:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#    BIR KEZ uretildikten sonra ASLA degistirme — degistirirsen kayitli SMTP sifreleri okunamaz hale gelir.
SMTP_ENCRYPTION_KEY=

# 7. Public Base URL (KRITIK: maillerdeki tracking/unsubscribe linkleri icin)
#    Domainin yoksa IP'yi kullan, ornek: https://mailkamp.senindomain.com
#    AYARLANMAZSA linkler request.host_url'a bakar (reverse proxy'de yanlis gidebilir).
PUBLIC_BASE_URL=

# 8. Zaman Dilimi (zamanlanmış mailler için)
TZ=Europe/Istanbul

# 9. (Opsiyonel) Rate Limiter storage. Birden fazla worker ile Redis öneririz.
#    Bos birakirsan bellek kullanir (her worker ayri sayar).
# MAILKAMP_RATELIMIT_STORAGE=redis://redis:6379/0

# 10. (Opsiyonel) Veritabani yolu. Docker'da default /app/instance/web_mailer_v6.db olur.
# MAILKAMP_DB_PATH=/app/instance/web_mailer_v6.db
