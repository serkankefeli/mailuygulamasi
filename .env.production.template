# =========================================================
# MAILKAMP - SUNUCU (PRODUCTION) .env DOSYASI ŞABLONU
# =========================================================
# Sunucuda yapilacak:
#   1) Bu dosyayi .env olarak kopyala:
#        cp .env.production.template .env
#   2) Asagidaki MUTLAKA ayarlanacak olan degerleri kendi
#      degerlerinle doldur (alttaki 'MUTLAKA DOLDUR' notlari).
#   3) docker-compose up -d --build
# =========================================================

# --- CALISMA ORTAMI ---
MAILKAMP_ENV=production
TZ=Europe/Istanbul

# --- PUBLIC URL (MAILLERDEKI TRACKING LINKLERI ICIN) ---
# Bu URL, gonderilen maillerin icindeki tracking pixel'i,
# unsubscribe ve video izleme linklerinde kullanilacak.
# HTTPS KULLAN (https://...). Sonda slash olmamali.
PUBLIC_BASE_URL=https://mailkamp.com

# --- FLASK GIZLI ANAHTARI ---
# Oturum cookie'leri ve HMAC imzalar icin. Lokaldekinden FARKLI
# olmasi daha guvenli (rotate edince lokal oturumlar etkilenmez).
# Yeni anahtar uretmek icin:
#   python -c "import secrets; print(secrets.token_hex(32))"
# MUTLAKA DOLDUR:
MAILKAMP_SECRET_KEY=9a8b7c6d5e4f3a2b1c0d9e8f7a6b5c4d3e2f1a0b9c8d7e6f5a4b3c2d1e0f9a8b

# --- FERNET SIFRELEME ANAHTARI (Kullanici SMTP sifreleri icin) ---
# ÇOK ONEMLI: LOKALDEKI DEGER ILE AYNI OLMALI!
# Eger bu anahtari degistirirsen, veritabanindaki sifreli SMTP
# sifreleri ACILAMAZ hale gelir ve kullanicilar mail gonderemez.
# MUTLAKA DOLDUR (lokaldeki .env'den aynisini kopyala):
SMTP_ENCRYPTION_KEY=6LK61aWKEN8xQ-pYyd88a3XXlFS0B5ftoQJ9Gybc3LU=

# --- ADMIN ILK SIFRESI ---
# Eger instance/web_mailer_v6.db yoksa (ilk kurulum), admin bu
# sifreyle olusturulur. Kurulum sonrasi bu sifreyi degistir.
ADMIN_INITIAL_PASSWORD=Admin12345!

# --- ADMIN SMTP SIFRESI (Gmail App Password) ---
# Sistem mailleri (sifre sifirlama, 2FA kodlari) bu adresten
# gider. Gmail "Uygulama Sifresi" (16 hane, bosluklu).
ADMIN_SMTP_PASSWORD=keql mzbq rcer ubii

# --- YONLENDIRME ALLOWLIST ---
# Bos kalabilir.
MAILKAMP_REDIRECT_ALLOWLIST=

# --- RATE LIMITER (opsiyonel, Redis onerilir) ---
# Gunicorn 3 worker ile calisiyorsa her worker ayri bellek kullanir,
# yani gercek rate limit 3 katina cikar. Dogru calismasi icin Redis ekle:
# MAILKAMP_RATELIMIT_STORAGE=redis://redis:6379/0

# --- VERITABANI YOLU (opsiyonel) ---
# Default: /app/instance/web_mailer_v6.db (Docker volume ile kalici)
# Ozel bir yol istemiyorsan BU SATIRI YORUM HALINDE BIRAK.
# MAILKAMP_DB_PATH=/app/instance/web_mailer_v6.db
